// Grantispro — Core Data Model
// Multi-tenant scholarship & donor management platform
// Tenant isolation via tenantId on every row (Postgres RLS applied at DB level later)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// TENANCY & USERS
// ---------------------------------------------------------------------------

enum InstitutionType {
  PRIVATE
  ISLAMIC
  SEMI_GOVT
  GOVT_FUNDED
  WAQF
  TRUST
  NGO
}

enum UserRole {
  SUPER_ADMIN
  INSTITUTION_ADMIN
  OFFICER
  FINANCE
  DONOR
}

model Tenant {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  institutionType  InstitutionType
  logoUrl          String?
  primaryColor     String?
  defaultCurrency  String          @default("USD")
  bankName         String?
  bankAccountTitle String?
  bankAccountNumber String?
  bankIban         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  users            User[]
  programs         ScholarshipProgram[]
  funds            Fund[]
  donors           Donor[]
  auditLogs        AuditLog[]
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  email        String    @unique
  passwordHash String?
  name         String
  role         UserRole
  donorId      String?   // set only when role = DONOR, scopes portal access to one Donor
  donor        Donor?    @relation(fields: [donorId], references: [id])
  createdAt    DateTime  @default(now())

  reviewScores ReviewScore[]
}

// ---------------------------------------------------------------------------
// SCHOLARSHIP PROGRAMS & DYNAMIC CRITERIA ENGINE
// ---------------------------------------------------------------------------

enum CriteriaLogic {
  ALL   // AND
  ANY   // OR
  SCORE // weighted scoring, admin sets a threshold
}

enum CriteriaFieldType {
  NUMBER
  TEXT
  BOOLEAN
  SELECT
}

model ScholarshipProgram {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  name          String
  description   String?
  isActive      Boolean       @default(true)
  requiresReview Boolean      @default(true)
  logicType     CriteriaLogic @default(ALL)
  scoreThreshold Int?
  createdAt     DateTime      @default(now())

  criteriaBlocks CriteriaBlock[]
  applications   Application[]
  funds          Fund[]        @relation("ProgramFunds")
  pledges        Pledge[]
}

// A single reusable, admin-defined eligibility rule (no hardcoded logic)
model CriteriaBlock {
  id          String            @id @default(cuid())
  programId   String
  program     ScholarshipProgram @relation(fields: [programId], references: [id])
  label       String            // e.g. "Household income below threshold"
  fieldType   CriteriaFieldType
  operator    String            // e.g. "lt", "gt", "eq", "in"
  value       String            // stored as string, cast per fieldType
  weight      Int               @default(1) // used when logicType = SCORE
  requiredDocumentLabel String? // e.g. "Income certificate" — suggested when created from a preset
  createdAt   DateTime          @default(now())
}

// Shared, seedable library of common scholarship eligibility rules
// (academic merit, financial need, demographic, institutional, talent, geographic).
// Not tenant-scoped — every institution sees the same starting library.
model PresetCriteria {
  id                    String            @id @default(cuid())
  category              String            // e.g. "Academic merit", "Financial need"
  label                 String
  fieldType             CriteriaFieldType
  operator              String
  defaultValue          String
  defaultWeight         Int               @default(1)
  suggestedDocumentLabel String?          // e.g. "Income certificate", null if no document implied
  sortOrder             Int               @default(0)
  createdAt             DateTime          @default(now())
}

// ---------------------------------------------------------------------------
// APPLICANTS & APPLICATIONS
// ---------------------------------------------------------------------------

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  AWARDED
  REJECTED
  RENEWED
}

// Tenant-configurable — a multi-campus institution defines its own list.
// Not hardcoded, since campus naming varies wildly (city names, "Boys/Girls",
// numbered branches, etc.)
model Campus {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  applicants Applicant[]
}

// Tenant-configurable — grade/class naming varies just as much (Grade 1-12,
// Hifz Year 1-5, university semesters, etc.), so this is a per-tenant list
// rather than a fixed enum.
model SchoolClass {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  applicants Applicant[]
}

model Applicant {
  id          String   @id @default(cuid())
  tenantId    String
  fullName    String
  dateOfBirth DateTime?
  guardianName String?
  contactEmail String?
  contactPhone String?
  photoUrl    String?  // uploaded via Cloudinary
  isZakatEligible Boolean @default(false) // relevant only for Islamic/Waqf institutions; ignored elsewhere
  campusId    String?
  campus      Campus?  @relation(fields: [campusId], references: [id])
  classId     String?
  schoolClass SchoolClass? @relation(fields: [classId], references: [id])
  metadata    Json?    // flexible bag for custom criteria fields (income, category, etc.)
  createdAt   DateTime @default(now())

  applications Application[]
  awards       Award[]
}

model Application {
  id          String             @id @default(cuid())
  tenantId    String
  programId   String
  program     ScholarshipProgram @relation(fields: [programId], references: [id])
  applicantId String
  applicant   Applicant          @relation(fields: [applicantId], references: [id])
  status      ApplicationStatus  @default(SUBMITTED)
  eligibilityScore Int?
  submittedAt DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  documents    Document[]
  reviewScores ReviewScore[]
  award        Award?
}

model Document {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  label         String      // e.g. "Income Certificate", "Guardian ID"
  fileUrl       String
  uploadedAt    DateTime    @default(now())
}

model ReviewScore {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  reviewerId    String
  reviewer      User        @relation(fields: [reviewerId], references: [id])
  score         Int
  comments      String?
  createdAt     DateTime    @default(now())
}

// ---------------------------------------------------------------------------
// FUNDS, DONORS & SPONSORSHIP
// ---------------------------------------------------------------------------

enum FundType {
  GENERAL
  RESTRICTED
  DONOR_DIRECTED
}

enum DonorType {
  INDIVIDUAL
  CORPORATE_CSR
  GOVERNMENT_GRANT
  FOREIGN_FUNDING
}

enum SponsorshipTargetType {
  STUDENT
  CLASS
  INSTITUTE
  PROJECT
  FUND
}

enum FundCategory {
  ZAKAT              // obligatory, Muslims only, must reach zakat-eligible recipients
  SADAQAH            // voluntary charity, anyone
  SADAQAH_JARIYAH    // ongoing/perpetual charity (e.g. a fund that keeps giving)
  FITRANA            // Zakat al-Fitr, given before Eid al-Fitr
  WAQF               // Islamic endowment — principal preserved, only proceeds used
  QURBANI            // Eid al-Adha sacrifice-linked charity
  GENERAL_DONATION   // secular/general giving, no religious designation
  CORPORATE_CSR
  GOVERNMENT_GRANT
  OTHER
}

model Fund {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  name        String
  type        FundType
  category    FundCategory @default(GENERAL_DONATION)
  balance     Decimal      @default(0) @db.Decimal(14, 2)
  currency    String       @default("USD")
  createdAt   DateTime     @default(now())

  programs      ScholarshipProgram[] @relation("ProgramFunds")
  allocations   SponsorshipLink[]
  disbursements Disbursement[]
  awards        Award[]
}

model Donor {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  type        DonorType
  contactEmail String?
  createdAt   DateTime  @default(now())

  pledges         Pledge[]
  sponsorshipLinks SponsorshipLink[]
  users           User[]
}

enum PledgeFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
}

enum PledgeMethod {
  CASH
  BANK_DEPOSIT
  CHEQUE
  BANK_TRANSFER
  ONLINE
}

enum PledgeDelivery {
  DONOR_SENDS      // donor will send/transfer funds themselves
  SCHOOL_COLLECTS  // institution arranges collection from the donor
}

model Pledge {
  id          String         @id @default(cuid())
  donorId     String
  donor       Donor          @relation(fields: [donorId], references: [id])
  programId   String?        // set when pledged via a program's public invite link
  program     ScholarshipProgram? @relation(fields: [programId], references: [id])
  amount      Decimal        @db.Decimal(14, 2)
  currency    String         @default("USD")
  category    FundCategory   @default(GENERAL_DONATION)
  frequency   PledgeFrequency @default(ONE_TIME)
  paymentMethod PledgeMethod @default(CASH)
  deliveryPreference PledgeDelivery @default(DONOR_SENDS)
  donorNote   String?        // e.g. collection address, special instructions
  committedAt DateTime       @default(now())
  receivedAt  DateTime?
}

// Links a donor's contribution to a specific target: a student, class, institute, project, or general fund
model SponsorshipLink {
  id          String                @id @default(cuid())
  donorId     String
  donor       Donor                 @relation(fields: [donorId], references: [id])
  fundId      String
  fund        Fund                  @relation(fields: [fundId], references: [id])
  targetType  SponsorshipTargetType
  targetId    String?               // applicantId / classId / instituteId / projectId — nullable for FUND-level
  createdAt   DateTime              @default(now())
}

enum AwardType {
  FULL
  PARTIAL_PERCENT
  FIXED_AMOUNT
}

model Award {
  id            String       @id @default(cuid())
  applicationId String?      @unique // set when awarded through the formal application flow
  application   Application? @relation(fields: [applicationId], references: [id])
  applicantId   String?      // set when granted directly to a student, bypassing the application flow
  applicant     Applicant?   @relation(fields: [applicantId], references: [id])
  fundId        String
  fund          Fund         @relation(fields: [fundId], references: [id])
  scholarshipName String
  awardType     AwardType    @default(FULL)
  percentValue  Int?         // used when awardType = PARTIAL_PERCENT
  amount        Decimal      @db.Decimal(14, 2) // full fee-equivalent value for FULL/PARTIAL_PERCENT, or the fixed amount
  currency      String       @default("USD")
  reason        String?      // e.g. "Need-based", "Merit-based", "Sibling discount"
  startDate     DateTime     @default(now())
  durationMonths Int?        // null = ongoing / open-ended
  awardedAt     DateTime     @default(now())

  disbursements Disbursement[]
}

model Disbursement {
  id          String   @id @default(cuid())
  awardId     String
  award       Award    @relation(fields: [awardId], references: [id])
  fundId      String
  fund        Fund     @relation(fields: [fundId], references: [id])
  amount      Decimal  @db.Decimal(14, 2)
  scheduledAt DateTime
  paidAt      DateTime?
  status      String   @default("SCHEDULED") // SCHEDULED | PAID | FAILED
}

// ---------------------------------------------------------------------------
// AUDIT
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  actorId   String?
  action    String   // e.g. "AWARD_CREATED", "CRITERIA_UPDATED"
  entity    String   // e.g. "Application:abc123"
  metadata  Json?
  createdAt DateTime @default(now())
}
